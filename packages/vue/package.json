{
  "name": "@fkui/vue",
  "version": "6.49.1",
  "description": "Vue implementation of FKUI components",
  "keywords": [
    "fkui",
    "designsystem",
    "vue"
  ],
  "homepage": "https://designsystem.forsakringskassan.se/",
  "bugs": "https://github.com/Forsakringskassan/designsystem/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/designsystem.git",
    "directory": "packages/vue"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.esm.js",
      "require": "./dist/cjs/index.cjs.js"
    },
    "./cypress": {
      "types": "./dist/types/cypress.d.ts",
      "import": "./dist/esm/cypress.esm.js",
      "require": "./dist/cjs/cypress.cjs.js"
    },
    "./selectors": {
      "types": "./dist/types/selectors.d.ts",
      "import": "./dist/esm/selectors.esm.js",
      "require": "./dist/cjs/selectors.cjs.js"
    },
    "./htmlvalidate": "./htmlvalidate/index.cjs",
    "./htmlvalidate/cypress": "./htmlvalidate/cypress.js",
    "./package.json": "./package.json",
    "./tsconfig.json": "./tsconfig-consumer.json"
  },
  "main": "dist/cjs/index.cjs.js",
  "module": "dist/esm/index.esm.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "htmlvalidate",
    "tsconfig-consumer.json",
    "!**/*.spec.{js,ts,d.ts}",
    "!**/.eslintrc.json",
    "!htmlvalidate/tsconfig.json"
  ],
  "scripts": {
    "prebuild": "run-s clean",
    "build": "run-s build:lib build:selectors build:dts build:api build:test-bundles",
    "build:api": "fk-api-extractor --patch-augmentations --patch-declare-var-vls api-extractor.*.json",
    "build:dts": "vue-tsc -b",
    "build:lib": "fk-build-vue-lib",
    "build:selectors": "fk-build-selectors",
    "build:test-bundles": "node build-test-bundles.mjs",
    "clean": "rimraf -g coverage dist public temp test-results",
    "prepack": "release-prepack --bundle --retain-scripts",
    "postpack": "release-postpack",
    "prepublishOnly": "release-prepublish --bundle --retain-scripts",
    "start": "vite --",
    "test": "vitest run --coverage",
    "unit": "vitest run",
    "unit:watch": "vitest"
  },
  "dependencies": {
    "@vueuse/core": "12.8.2",
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "@fkui/date": "6.49.1",
    "@fkui/design": "6.49.1",
    "@fkui/icon-lib-default": "6.49.1",
    "@fkui/logic": "6.49.1",
    "@fkui/test-utils": "6.49.1",
    "@fkui/theme-default": "6.49.1",
    "@forsakringskassan/vite-lib-config": "5.1.0",
    "@forsakringskassan/vitest-config-jsdom": "2.2.9",
    "@vue/test-utils": "2.4.11",
    "cypress": "15.16.0",
    "esbuild": "0.28.0",
    "flush-promises": "1.0.2",
    "glob": "13.0.6",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vue": "3.5.35",
    "vue-router": "4.6.4"
  },
  "peerDependencies": {
    "@fkui/date": "^6.49.1",
    "@fkui/design": "^6.49.1",
    "@fkui/logic": "^6.49.1",
    "fk-icons": "^4.30.1",
    "html-validate": ">= 10.10.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "fk-icons": {
      "optional": true
    },
    "html-validate": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.16 || >= 24",
    "npm": ">= 7"
  },
  "externalDependencies": []
}
