{
    "extends": ["@fkui/tsconfig/recommended", "@fkui/vue/tsconfig.json"],
    "compilerOptions": {
        "noEmit": true,
        "types": ["vite/client"],
        "skipLibCheck": true,
        "rootDir": "../../",
        "paths": {
            "@fkui/table-tests-examples/*": [
                "../../packages/vue/src/components/FTable/tests/*.vue"
            ],
            "@fkui/table-docs-examples/*": [
                "../../packages/vue/src/components/FTable/docs/*.vue"
            ]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.vue"]
}
